# Choose provider: groq | gemini
llm_provider=groq
allow_provider_fallback=true

# Optional: automatic routing across multiple models/providers (comma-separated).
# Example:
# llm_candidates=groq:llama-3.3-70b-versatile,groq:llama3-8b-8192,gemini:gemini-2.5-flash,gemini:gemini-2.0-flash
llm_candidates=
llm_cooldown_seconds=90
llm_first_token_timeout_seconds=1.2

# --- Groq ---
groq_api_key=YOUR_GROQ_KEY
groq_model=llama3-8b-8192
groq_max_tokens=500

# --- Gemini (Google GenAI) ---
gemini_api_key=YOUR_GEMINI_KEY
gemini_model=gemini-2.5-flash
gemini_fallback_model=gemini-2.0-flash
gemini_max_output_tokens=500

# Admin endpoint protection
admin_api_key=CHANGE_ME

# CORS
allowed_origins=http://localhost:3000,http://127.0.0.1:3000
